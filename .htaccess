# Disable directory listing (prevent browsing folder contents)
Options -Indexes

# Block access to sensitive and configuration files
<FilesMatch "^(\.env|\.env\.example|\.gitignore|\.htaccess|database\.php)$">
    Require all denied
    Order allow,deny
    Deny from all
</FilesMatch>

# Fallback protection for all dotfiles
<FilesMatch "^\.">
    Require all denied
    Order allow,deny
    Deny from all
</FilesMatch>
